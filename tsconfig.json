{
	"extends": "@tsconfig/svelte/tsconfig.json",
	"compilerOptions": {
		"target": "esnext",
		"allowJs": true,
		"checkJs": true,
		"noEmit": true,
		"types": ["svelte", "vite/client"]
	},
	"include": ["src/**/*.ts", "src/**/*.js", "src/**/*.svelte"],
	"references": [
		{
			"path": "./tsconfig.node.json"
		}
	]
}
